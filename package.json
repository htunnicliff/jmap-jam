{
  "private": true,
  "packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820",
  "prettier": {
    "trailingComma": "none",
    "plugins": [
      "@prettier/plugin-oxc"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "oxlint --type-aware",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spelling:check": "cspell .",
    "version": "pnpm run build && changeset version && pnpm install",
    "publish": "pnpm run build && pnpm publish --recursive --access public",
    "sync:readme": "cp packages/jmap-jam/README.md README.md"
  },
  "devDependencies": {
    "@changesets/cli": "2.31.0",
    "@prettier/plugin-oxc": "0.1.4",
    "@types/node": "24.12.2",
    "cspell": "9.8.0",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "prettier": "3.8.3"
  }
}
