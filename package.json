{
  "private": true,
  "packageManager": "pnpm@10.25.0+sha512.5e82639027af37cf832061bcc6d639c219634488e0f2baebe785028a793de7b525ffcd3f7ff574f5e9860654e098fe852ba8ac5dd5cefe1767d23a020a92f501",
  "prettier": {
    "trailingComma": "none",
    "plugins": [
      "@prettier/plugin-oxc"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "oxlint --type-aware",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spelling:check": "cspell .",
    "version": "pnpm run build && changeset version && pnpm install",
    "publish": "pnpm run build && pnpm publish --recursive --access public",
    "sync:readme": "cp packages/jmap-jam/README.md README.md"
  },
  "devDependencies": {
    "@changesets/cli": "2.29.7",
    "@prettier/plugin-oxc": "0.0.5",
    "@types/node": "24.10.1",
    "cspell": "9.3.2",
    "oxlint": "1.29.0",
    "oxlint-tsgolint": "0.7.3",
    "prettier": "3.6.2"
  }
}
