{
  "private": true,
  "packageManager": "pnpm@10.32.0+sha512.9b2634bb3fed5601c33633f2d92593f506270a3963b8c51d2b2d6a828da615ce4e9deebef9614ccebbc13ac8d3c0f9c9ccceb583c69c8578436fa477dbb20d70",
  "prettier": {
    "trailingComma": "none",
    "plugins": [
      "@prettier/plugin-oxc"
    ]
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "oxlint --type-aware",
    "test": "pnpm -r test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "spelling:check": "cspell .",
    "version": "pnpm run build && changeset version && pnpm install",
    "publish": "pnpm run build && pnpm publish --recursive --access public",
    "sync:readme": "cp packages/jmap-jam/README.md README.md"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@prettier/plugin-oxc": "0.1.3",
    "@types/node": "24.12.0",
    "cspell": "9.7.0",
    "oxlint": "1.52.0",
    "oxlint-tsgolint": "0.16.0",
    "prettier": "3.8.1"
  }
}
